// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum RoleUser {
  ADMIN
  HR
  EMPLOYEE
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  PAID
}

enum EmploymentStatus {
  ACTIVE
  RESIGNED
  TERMINATED
}

enum JobLevel {
  JUNIOR
  MIDDLE
  SENIOR
  LEAD
  MANAGER
}

model User {
  id                     Int             @id @default(autoincrement())
  email                  String          @unique
  password               String
  role                   RoleUser        @default(EMPLOYEE)
  is_deleted             Boolean         @default(false)
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  employee               Employee?
  reimbursementsApproved Reimbursement[] @relation("ApprovedBy")
  overtimesCreated       Overtime[]
  payrollsGenerated      Payroll[]
}

model Division {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  description   String?
  is_deleted    Boolean       @default(false)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  job_positions JobPosition[]
}

model JobPosition {
  id             Int        @id @default(autoincrement())
  division_id    Int
  position_name  String
  level          JobLevel
  default_salary Decimal    @db.Decimal(15, 2)
  description    String?
  is_deleted     Boolean    @default(false)
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  division       Division   @relation(fields: [division_id], references: [id])
  employees      Employee[]
}

model Employee {
  id                Int              @id @default(autoincrement())
  user_id           Int?             @unique
  employee_code     String           @unique
  job_position_id   Int
  full_name         String
  phone             String?
  join_date         DateTime
  base_salary       Decimal          @db.Decimal(15, 2)
  bank_name         String?
  bank_account      String?
  employment_status EmploymentStatus @default(ACTIVE)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  job_position      JobPosition      @relation(fields: [job_position_id], references: [id])
  user              User?            @relation(fields: [user_id], references: [id])
  reimbursements    Reimbursement[]
  overtimes         Overtime[]
  payrolls          Payroll[]

  @@index([employment_status])
}

model Reimbursement {
  id          Int                 @id @default(autoincrement())
  employee_id Int
  payroll_id  Int?
  title       String
  description String?
  amount      Decimal             @db.Decimal(15, 2)
  proof_file  String?
  status      ReimbursementStatus @default(PENDING)
  approved_by Int?
  approved_at DateTime?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  employee    Employee            @relation(fields: [employee_id], references: [id])
  approver    User?               @relation("ApprovedBy", fields: [approved_by], references: [id])
  payroll     Payroll?            @relation(fields: [payroll_id], references: [id])
}

model Overtime {
  id          Int      @id @default(autoincrement())
  employee_id Int
  payroll_id  Int?
  date        DateTime
  hours       Float
  amount      Decimal  @db.Decimal(15, 2)
  notes       String?
  created_by  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  employee    Employee @relation(fields: [employee_id], references: [id])
  payroll     Payroll? @relation(fields: [payroll_id], references: [id])
  creator     User     @relation(fields: [created_by], references: [id])
}

model Payroll {
  id                  Int             @id @default(autoincrement())
  employee_id         Int
  month               Int
  year                Int
  basic_salary        Decimal         @db.Decimal(15, 2)
  overtime_total      Decimal         @db.Decimal(15, 2)
  reimbursement_total Decimal         @db.Decimal(15, 2)
  tax                 Decimal         @db.Decimal(15, 2)
  other_deduction     Decimal         @default(0) @db.Decimal(15, 2)
  gross_salary        Decimal         @db.Decimal(15, 2)
  net_salary          Decimal         @db.Decimal(15, 2)
  status              PayrollStatus   @default(DRAFT)
  generated_by        Int
  generated_at        DateTime        @default(now())
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  employee            Employee        @relation(fields: [employee_id], references: [id])
  generator           User            @relation(fields: [generated_by], references: [id])
  payslip             Payslip?
  overtimes           Overtime[]
  reimbursements      Reimbursement[]

  @@unique([employee_id, month, year])
  @@index([status])
}

model Payslip {
  id           Int      @id @default(autoincrement())
  payroll_id   Int      @unique
  slip_number  String   @unique
  generated_at DateTime @default(now())
  payroll      Payroll  @relation(fields: [payroll_id], references: [id])
}
